# ── Frontend (Vercel) ───────────────────────────────────────────────────────
# Your Render API URL — set this in Vercel → Project → Settings → Environment Variables
# Example: https://mktv-api.onrender.com
VITE_API_URL=

# ── API server (Render) ─────────────────────────────────────────────────────
# Render sets PORT automatically; only needed for local dev:
PORT=5000
